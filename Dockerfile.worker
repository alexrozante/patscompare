FROM node:20-bullseye-slim

ENV ROLE=worker

ENV NODE_ENV=production
ENV REDIS_HOST=redis

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      poppler-utils \
      ca-certificates \
      curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /opt/patscompare

COPY entrypoint.sh start.sh package.json package-lock.json ./
COPY server ./server

RUN chmod +x ./entrypoint.sh ./start.sh

RUN npm ci --production

ENTRYPOINT ["/opt/patscompare/entrypoint.sh"]